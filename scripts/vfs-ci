#!/usr/bin/env python3
"""
vfs-ci - Manage CI for linux-fsdevel/vfs

Standalone tool for managing the VFS CI infrastructure. Provides
commands to sync CI files, run the mailing-list-to-PR bridge,
cancel CI runs, and clean up branches.

Designed to be self-contained with no external dependencies beyond
the gh CLI tool.
"""

import argparse
import json
import os
import shutil
import subprocess
import sys
import time
from pathlib import Path
from urllib.parse import unquote

# ── ANSI colors ──────────────────────────────────────────────────────

class C:
    BOLD = RESET = RED = GREEN = YELLOW = BLUE = DIM = ""

    @classmethod
    def init(cls):
        if sys.stdout.isatty():
            cls.BOLD = "\033[1m"
            cls.RESET = "\033[0m"
            cls.RED = "\033[31m"
            cls.GREEN = "\033[32m"
            cls.YELLOW = "\033[33m"
            cls.BLUE = "\033[34m"
            cls.DIM = "\033[2m"


def info(msg):
    print(f"{C.BOLD}{msg}{C.RESET}")

def ok(msg):
    print(f"  {C.GREEN}ok{C.RESET}   {msg}")

def warn(msg):
    print(f"  {C.YELLOW}warn{C.RESET} {msg}")

def err(msg):
    print(f"  {C.RED}err{C.RESET}  {msg}")

def die(msg):
    print(f"{C.RED}fatal:{C.RESET} {msg}", file=sys.stderr)
    sys.exit(1)


# ── Configuration ────────────────────────────────────────────────────

VMTEST_REPO = "linux-fsdevel/vfs-test"
VFS_REPO = "linux-fsdevel/vfs"
POLL_INTERVAL = 10
POLL_TIMEOUT = 600
VFS_TEST = Path(__file__).resolve().parent.parent


# ── Helpers ──────────────────────────────────────────────────────────

def parse_pr_range(value):
    """Parse a PR number or range (e.g. '235' or '235-240')."""
    if "-" in value:
        parts = value.split("-", 1)
        try:
            start, end = int(parts[0]), int(parts[1])
        except ValueError:
            raise argparse.ArgumentTypeError(f"invalid range: {value}")
        if start > end:
            raise argparse.ArgumentTypeError(f"invalid range: {value}")
        return list(range(start, end + 1))
    try:
        return [int(value)]
    except ValueError:
        raise argparse.ArgumentTypeError(f"invalid PR number: {value}")


def expand_prs(raw):
    """Flatten a list of parse_pr_range results into unique PR numbers."""
    seen = set()
    result = []
    for item in raw:
        for n in item:
            if n not in seen:
                seen.add(n)
                result.append(n)
    return result


def gh(*args, check=True, capture=False):
    """Run a gh CLI command."""
    cmd = ["gh"] + list(args)
    if capture:
        return subprocess.run(cmd, capture_output=True, text=True, check=check)
    return subprocess.run(cmd, text=True, check=check)


def gh_json(*args):
    """Run a gh CLI command and parse JSON output."""
    result = gh(*args, capture=True, check=False)
    if result.returncode != 0 or not result.stdout.strip():
        return None
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError:
        return None


def check_gh():
    """Verify gh CLI is available and authenticated."""
    try:
        subprocess.run(["gh", "auth", "status"],
                       capture_output=True, text=True, check=True)
    except FileNotFoundError:
        die("gh CLI not found. Install it: https://cli.github.com/")
    except subprocess.CalledProcessError:
        die("gh CLI not authenticated. Run: gh auth login")


def _poll(fetch_fn, label, quiet=False, initial_delay=0):
    """Poll until completion. fetch_fn() returns (status, conclusion) or None."""
    if initial_delay:
        time.sleep(initial_delay)

    start = time.monotonic()
    last_status = ""

    while True:
        elapsed = time.monotonic() - start
        if elapsed >= POLL_TIMEOUT:
            err(f"Timed out after {POLL_TIMEOUT}s")
            return False

        result = fetch_fn()
        if not result:
            time.sleep(POLL_INTERVAL)
            continue

        status, conclusion = result

        if status != last_status and not quiet:
            print(f"  {C.DIM}{label}: {status}{C.RESET}", flush=True)
            last_status = status

        if status == "completed":
            if conclusion == "success":
                ok(f"{label} completed successfully")
                return True
            else:
                err(f"{label} finished: {conclusion}")
                return False

        time.sleep(POLL_INTERVAL)



def poll_workflow(repo, workflow, label="", quiet=False):
    """Poll the most recent run of a workflow until completion."""
    def fetch():
        data = gh_json("run", "list", "--repo", repo,
                        f"--workflow={workflow}", "--limit=1",
                        "--json", "databaseId,status,conclusion")
        if not data:
            return None
        run = data[0]
        return run["status"], run.get("conclusion") or ""
    return _poll(fetch, label or workflow, quiet, initial_delay=3)


# ── Commands ─────────────────────────────────────────────────────────

def trigger_and_poll(args, workflow, label, force_wait=False):
    """Trigger a workflow and optionally poll for completion."""
    info(f"Triggering {label}...")
    gh("workflow", "run", workflow, "--repo", VMTEST_REPO)
    ok(f"{workflow} triggered")
    if force_wait or getattr(args, "wait", False):
        poll_workflow(VMTEST_REPO, workflow, label, args.quiet)


def cmd_sync(args):
    """Sync CI files to vfs base branches."""
    trigger_and_poll(args, "sync.yml", "sync")


def cmd_bridge(args):
    """Run the mailing-list-to-PR bridge."""
    trigger_and_poll(args, "bridge.yml", "bridge")



def delete_pr(num):
    """Close a PR and delete its branch. Returns True on success."""
    data = gh_json("pr", "view", str(num), "--repo", VFS_REPO,
                    "--json", "state,headRefName")
    if not data:
        return False

    branch = data["headRefName"]
    if data["state"] == "CLOSED" or data["state"] == "MERGED":
        warn(f"PR #{num} already {data['state'].lower()}")
    else:
        gh("pr", "close", str(num), "--repo", VFS_REPO,
           check=False, capture=True)

    if branch.startswith("pw/"):
        gh("api", "-X", "DELETE",
           f"repos/linux-fsdevel/vfs/git/refs/heads/{branch}",
           check=False, capture=True)
        ok(f"PR #{num} closed, branch {branch} deleted")
    else:
        ok(f"PR #{num} closed (branch {branch} kept)")

    return True


def delete_orphan_branches():
    """Delete pw/ branches that have no associated open PR."""
    info("Deleting orphan pw/ branches...")
    result = gh("api", "repos/linux-fsdevel/vfs/branches", "--paginate",
                "--jq", ".[].name", capture=True, check=False)
    if result.returncode != 0:
        warn("Failed to list branches")
        return

    branches = [b.strip() for b in result.stdout.strip().split("\n")
                if b.strip().startswith("pw/")]
    if not branches:
        info("  No pw/ branches")
        return

    for branch in branches:
        gh("api", "-X", "DELETE",
           f"repos/linux-fsdevel/vfs/git/refs/heads/{branch}",
           check=False, capture=True)

    ok(f"Deleted {len(branches)} branch(es)")


def cmd_delete(args):
    """Close PRs and delete their branches."""
    if getattr(args, "all", False):
        prs = gh_json("pr", "list", "--repo", VFS_REPO, "--state=open",
                       "--limit=200", "--json", "number")
        if prs:
            info(f"Deleting {len(prs)} open PR(s)...")
            for i, pr in enumerate(prs, 1):
                num = pr["number"]
                print(f"  [{i}/{len(prs)}] ", end="", flush=True)
                delete_pr(num)
        else:
            info("  No open PRs")

        delete_orphan_branches()
        return

    if not getattr(args, "pr", None):
        die("Specify --pr NUMBER [NUMBER...] or --all")

    for pr in expand_prs(args.pr):
        delete_pr(pr)


def cmd_cancel(args):
    """Cancel running/queued workflows."""
    if getattr(args, "pr", None):
        for pr in expand_prs(args.pr):
            data = gh_json("pr", "view", str(pr), "--repo", VFS_REPO,
                            "--json", "headRefName")
            if not data:
                continue

            branch = data["headRefName"]
            runs = gh_json("run", "list", "--repo", VFS_REPO,
                            f"--branch={branch}", "--limit=20",
                            "--json", "databaseId,status")
            if not runs:
                warn(f"No runs found for PR #{pr}")
                continue

            active = [r for r in runs if r["status"] != "completed"]
            if not active:
                info(f"  No active runs for PR #{pr}")
                continue

            for run in active:
                gh("run", "cancel", str(run["databaseId"]),
                   "--repo", VFS_REPO, check=False, capture=True)

            ok(f"Cancelled {len(active)} run(s) for PR #{pr}")
        return

    repos = [VFS_REPO]
    if args.all:
        repos.append(VMTEST_REPO)

    for repo in repos:
        info(f"Cancelling active runs on {repo}...")
        data = gh_json("run", "list", "--repo", repo, "--limit=200",
                        "--json", "databaseId,status")
        if not data:
            info(f"  No runs on {repo}")
            continue

        active = [r for r in data if r["status"] != "completed"]
        if not active:
            info(f"  No active runs on {repo}")
            continue

        for run in active:
            gh("run", "cancel", str(run["databaseId"]), "--repo", repo,
               check=False, capture=True)

        ok(f"Cancelled {len(active)} run(s) on {repo}")


def cmd_reset(args):
    """Full reset: cancel all, clean branches, sync, bridge."""
    info("Full CI reset...")
    reset_args = argparse.Namespace(all=True, pr=None,
                                    quiet=args.quiet, wait=args.wait)
    cmd_cancel(reset_args)
    cmd_delete(reset_args)
    trigger_and_poll(args, "sync.yml", "sync", force_wait=True)
    trigger_and_poll(args, "bridge.yml", "bridge")


def cmd_status(args):
    """Show current CI status."""
    info("Active runs on linux-fsdevel/vfs:")
    data = gh_json("run", "list", "--repo", VFS_REPO, "--limit=20",
                    "--json", "databaseId,status,conclusion,headBranch,name")
    if not data:
        print("  (none)")
    else:
        active = [r for r in data if r["status"] != "completed"]
        completed = [r for r in data if r["status"] == "completed"][:5]

        if active:
            for r in active:
                print(f"  {C.YELLOW}{r['status']:12}{C.RESET} "
                      f"{r['headBranch']} ({r['databaseId']})")
        else:
            print("  No active runs")

        if completed and not args.quiet:
            print()
            info("Recent completed:")
            for r in completed:
                color = C.GREEN if r["conclusion"] == "success" else C.RED
                print(f"  {color}{r['conclusion']:12}{C.RESET} "
                      f"{r['headBranch']} ({r['databaseId']})")

    print()
    prs = gh_json("pr", "list", "--repo", VFS_REPO, "--state=open",
                   "--limit=200", "--json", "number")
    info(f"Open PRs: {len(prs) if prs else 0}")


def find_pr_by_msgid(msgid):
    """Find a PR number by searching for a message ID in PR bodies."""
    # Try GitHub search first
    query = f'repo:{VFS_REPO} is:pr "{msgid}"'
    result = gh("api", "search/issues", "--method", "GET",
                "-f", f"q={query}",
                "--jq", ".items | sort_by(.number) | reverse | .[0].number",
                capture=True, check=False)

    pr_num = result.stdout.strip()
    if pr_num and pr_num != "null":
        return pr_num

    # Fallback: scan recent open PRs (search index may lag)
    prs = gh_json("pr", "list", "--repo", VFS_REPO, "--state=all",
                  "--limit=100", "--json", "number,body")
    if prs:
        for pr in prs:
            if msgid in (pr.get("body") or ""):
                return str(pr["number"])

    return None


def cmd_ci_results(args):
    """Fetch and display CI results for a lore message ID."""
    raw = args.msgid.strip()

    # Accept full lore URL — extract the path component containing '@'
    # Handles /T/, /raw, anchors, and URL-encoded characters
    if "lore.kernel.org" in raw:
        parts = raw.rstrip("/").split("/")
        for part in parts:
            if "@" in part:
                raw = unquote(part)
                break

    msgid = raw.strip("<>")

    if not args.quiet:
        info(f"Looking up CI for <{msgid}>...")

    pr_num = find_pr_by_msgid(msgid)
    if not pr_num:
        die(f"No PR found for message-id: <{msgid}>")

    pr_data = gh_json("pr", "view", pr_num, "--repo", VFS_REPO,
                      "--json", "number,title,headRefName")
    if not pr_data:
        die(f"Failed to fetch PR #{pr_num}")

    if not args.quiet:
        ok(f"PR #{pr_num}: {pr_data['title']}")

    # Get check runs for the PR
    # gh pr checks fields: bucket, name, state, link, workflow
    result = gh("pr", "checks", pr_num, "--repo", VFS_REPO,
                "--json", "name,state,bucket,link",
                capture=True, check=False)

    checks = []
    if result.stdout.strip():
        try:
            checks = json.loads(result.stdout)
        except json.JSONDecodeError:
            pass

    # Filter to actual test jobs
    test_checks = [c for c in checks if c.get("name", "") != "set-matrix"]

    if not test_checks:
        warn("No CI results found (CI may not have run yet)")
        return

    # Extract run URL from any job link
    # link format: https://github.com/.../actions/runs/<run_id>/job/<job_id>
    run_url = None
    for c in test_checks:
        link = c.get("link", "")
        if "/actions/runs/" in link:
            run_url = link.split("/job/")[0]
            break

    # Machine-readable output
    if getattr(args, "json_output", False):
        def status_str(check):
            bucket = (check.get("bucket") or "").lower()
            state = (check.get("state") or "").upper()
            if bucket in ("pass", "fail", "pending", "skipping"):
                return bucket
            if state == "CANCELLED":
                return "cancelled"
            return (bucket or state or "unknown").lower()

        out = {
            "pr": int(pr_num),
            "title": pr_data["title"],
            "run_url": run_url,
            "checks": [
                {
                    "name": c["name"].replace(" / build-and-test", ""),
                    "status": status_str(c),
                    "link": c.get("link", ""),
                }
                for c in sorted(test_checks, key=lambda c: c["name"])
            ],
        }
        print(json.dumps(out, indent=2))
        return

    # Format plain-text output suitable for email
    def clean_name(name):
        return name.replace(" / build-and-test", "")

    def get_status(check):
        bucket = (check.get("bucket") or "").lower()
        state = (check.get("state") or "").upper()
        if bucket == "pass":
            return "pass", C.GREEN
        elif bucket == "fail":
            return "FAIL", C.RED
        elif bucket == "pending":
            return "running", C.YELLOW
        elif bucket == "skipping":
            return "skip", C.DIM
        elif state == "CANCELLED":
            return "cancelled", C.YELLOW
        else:
            return (bucket or state or "unknown").lower(), C.DIM

    names = [clean_name(c["name"]) for c in test_checks]
    pad = max(len(n) for n in names)

    print()
    if run_url:
        print(f"VFS CI: {run_url}")
    else:
        print("VFS CI:")
    print()

    for c in sorted(test_checks, key=lambda c: c["name"]):
        name = clean_name(c["name"])
        status, color = get_status(c)
        suffix = ""
        if status == "FAIL" and c.get("link"):
            suffix = f"\n  {C.DIM}{c['link']}{C.RESET}"
        print(f"  {name:<{pad}}  {color}{status}{C.RESET}{suffix}")

    print()


def needs_fstests(suite):
    """Whether the given suite selection requires fstests."""
    return suite != "selftests"


def needs_ovl(suite):
    """Whether the given suite selection requires unionmount-testsuite."""
    return suite is None or suite == "ovl-fstests"


def run_suite(mkosi_kernel, unit, label):
    """Run a test suite in QEMU via mkosi. Returns True on success."""
    info(f"Running {label} in QEMU...")
    result = subprocess.run(
        ["mkosi", f"--directory={mkosi_kernel}", "box", "--",
         "mkosi", f"--directory={mkosi_kernel}",
         f"--kernel-command-line-extra=systemd.unit={unit}", "qemu"],
        text=True)
    if result.returncode != 123:
        err(f"{label.upper()} FAILED (exit code {result.returncode})")
        return False
    ok(f"{label} passed")
    return True


def ensure_repos(base, suite):
    """Clone mkosi-kernel, fstests, unionmount-testsuite if missing."""
    mkosi_kernel = base / "mkosi-kernel"
    fstests = base / "fstests"

    if not mkosi_kernel.is_dir():
        info(f"Cloning mkosi-kernel to {mkosi_kernel}...")
        subprocess.run(["git", "clone", "--depth=1",
                        "https://github.com/DaanDeMeyer/mkosi-kernel.git",
                        str(mkosi_kernel)], check=True)

    if needs_fstests(suite) and not fstests.is_dir():
        info(f"Cloning fstests to {fstests}...")
        subprocess.run(["git", "clone", "--depth=1",
                        "https://github.com/kdave/xfstests.git",
                        str(fstests)], check=True)

    unionmount = fstests / "src" / "unionmount-testsuite"
    if needs_ovl(suite) and not unionmount.is_dir():
        info(f"Cloning unionmount-testsuite into {fstests}/src/...")
        subprocess.run(["git", "clone", "--depth=1",
                        "https://github.com/amir73il/unionmount-testsuite.git",
                        str(unionmount)], check=True)

    return mkosi_kernel, fstests


def configure_mkosi(mkosi_kernel, fstests, kernel_src, suite, distro):
    """Overlay VFS CI config onto mkosi-kernel and generate mkosi.local.conf."""
    ci_mkosi = VFS_TEST / "ci" / "mkosi"
    info("Configuring mkosi...")

    shutil.copy2(ci_mkosi / "mkosi.kernel.config", mkosi_kernel)
    shutil.copytree(ci_mkosi / "mkosi.extra", mkosi_kernel / "mkosi.extra",
                    dirs_exist_ok=True)
    shutil.copytree(ci_mkosi / "mkosi.repart", mkosi_kernel / "mkosi.repart",
                    dirs_exist_ok=True)

    conf_d = mkosi_kernel / "mkosi.conf.d"
    conf_d.mkdir(parents=True, exist_ok=True)

    # Strip BuildSources from drop-ins — they reference CI env vars
    # ($GITHUB_WORKSPACE, $MKOSI_FSTESTS) that don't exist locally.
    # BuildSources is set in mkosi.local.conf instead; ExtraTrees is
    # rewritten with the expanded local path.
    src = (ci_mkosi / "mkosi.conf.d" / "99-vfs.conf").read_text()
    (conf_d / "99-vfs.conf").write_text(
        "\n".join(l for l in src.splitlines()
                  if not l.startswith("BuildSources=")) + "\n")

    if needs_fstests(suite):
        src = (ci_mkosi / "mkosi.conf.d" / "99-vfs-fstests.conf").read_text()
        (conf_d / "99-vfs-fstests.conf").write_text(
            "\n".join(l for l in src.splitlines()
                      if not l.startswith("BuildSources=")) + "\n")

    if needs_ovl(suite):
        src = (ci_mkosi / "mkosi.conf.d" / "99-vfs-ovl.conf").read_text()
        (conf_d / "99-vfs-ovl.conf").write_text(
            src.replace("$MKOSI_FSTESTS", str(fstests)))

    # Generate mkosi.local.conf
    buildsources = f"{kernel_src}:kernel"
    if needs_fstests(suite):
        buildsources += f"\n            {fstests}:fstests"

    (mkosi_kernel / "mkosi.local.conf").write_text(
        f"[Distribution]\nDistribution={distro}\n\n"
        f"[Build]\nBuildSources={buildsources}\n")


def cmd_local_test(args):
    """Run VFS CI mkosi build & tests locally."""
    kernel_src = Path(args.kernel_src).resolve()
    if not kernel_src.is_dir():
        die(f"Kernel source directory not found: {kernel_src}")

    suite = args.suite
    distro = args.distro
    base = Path(args.directory)

    mkosi_kernel, fstests = ensure_repos(base, suite)

    # Print configuration
    info(f"Kernel source:          {kernel_src}")
    info(f"mkosi-kernel:           {mkosi_kernel}")
    if needs_fstests(suite):
        info(f"fstests:                {fstests}")
    if needs_ovl(suite):
        info(f"unionmount-testsuite:   {fstests / 'src' / 'unionmount-testsuite'}")
    info(f"Distribution:           {distro}")
    info(f"Test suite:             {suite or 'all'}")

    configure_mkosi(mkosi_kernel, fstests, kernel_src, suite, distro)

    # Generate signing keys if not present
    if not (mkosi_kernel / "mkosi.key").exists():
        info("Generating signing keys...")
        subprocess.run(["mkosi", f"--directory={mkosi_kernel}", "genkey"],
                       check=True)

    # Build
    info("mkosi summary")
    subprocess.run(["mkosi", f"--directory={mkosi_kernel}", "summary"],
                   check=True, env={**os.environ, "PAGER": "cat", "SYSTEMD_PAGER": "cat"})

    info("Building image and kernel...")
    subprocess.run(["mkosi", f"--directory={mkosi_kernel}", "-f", "build"],
                   check=True)

    # Run test suites
    suites = {
        "selftests":  ("vfs-selftests.service",  "selftests"),
        "xfstests":   ("xfs-fstests.service",    "xfs fstests"),
        "ovl-fstests": ("ovl-fstests.service",   "overlayfs fstests"),
    }

    targets = [suite] if suite else list(suites.keys())
    for name in targets:
        unit, label = suites[name]
        if not run_suite(str(mkosi_kernel), unit, label):
            sys.exit(1)

    ok("ALL TESTS PASSED")


# ── Main ─────────────────────────────────────────────────────────────

GH_COMMANDS = {"sync", "bridge", "delete", "cancel",
               "reset", "status", "ci-results"}


def parse_args():
    parser = argparse.ArgumentParser(
        description="Manage CI for linux-fsdevel/vfs",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  vfs-ci sync -w               # Sync and wait
  vfs-ci bridge                # Run bridge
  vfs-ci delete --pr 235       # Close PR #235 + delete branch
  vfs-ci delete --pr 235-240   # Close PRs #235 through #240
  vfs-ci delete --all          # Close all PRs + delete pw/ branches
  vfs-ci cancel                # Cancel all vfs CI runs
  vfs-ci cancel --pr 235       # Cancel runs for PR #235
  vfs-ci cancel --all          # Cancel all runs (both repos)
  vfs-ci reset                 # Full nuclear reset
  vfs-ci reset -w              # Full reset, wait for bridge
  vfs-ci status                # Show CI status
  vfs-ci ci-results '<20250321-foo-v1-0-abc123@kernel.org>'
  vfs-ci ci-results https://lore.kernel.org/linux-fsdevel/20250321-foo-v1-0-abc123@kernel.org/
  vfs-ci local-test -k ~/linux               # Build & run all suites
  vfs-ci local-test -k ~/linux --suite selftests
  vfs-ci local-test -k ~/linux -d ~/ci --suite xfstests
"""
    )

    parser.add_argument("-q", "--quiet", action="store_true",
                        help="Suppress informational messages")

    sub = parser.add_subparsers(dest="command", required=True,
                                metavar="COMMAND")

    # ── GitHub CI commands ───────────────────────────────────────
    p = sub.add_parser("sync", help="Sync CI files to vfs base branches")
    p.add_argument("-w", "--wait", action="store_true")

    p = sub.add_parser("bridge", help="Run the mailing-list-to-PR bridge")
    p.add_argument("-w", "--wait", action="store_true")

    p = sub.add_parser("delete", help="Close PR(s) and delete pw/ branches")
    p.add_argument("--pr", type=parse_pr_range, nargs='+',
                   metavar="N", help="PR number(s) or range (e.g. 235-240)")
    p.add_argument("--all", action="store_true",
                   help="All open PRs + orphan pw/ branches")

    p = sub.add_parser("cancel", help="Cancel active CI runs")
    p.add_argument("--pr", type=parse_pr_range, nargs='+',
                   metavar="N", help="PR number(s) or range (e.g. 235-240)")
    p.add_argument("--all", action="store_true",
                   help="Include vfs-test repo")

    p = sub.add_parser("reset",
                       help="Full reset: cancel + delete --all + sync + bridge")
    p.add_argument("-w", "--wait", action="store_true")

    sub.add_parser("status", help="Show current CI status")

    p = sub.add_parser("ci-results",
                       help="Show CI results for a lore message ID")
    p.add_argument("msgid",
                   help="Message-ID, <Message-ID>, or lore.kernel.org URL")
    p.add_argument("--json", action="store_true", dest="json_output",
                   help="Emit machine-readable JSON output")

    # ── Local test command ───────────────────────────────────────
    p = sub.add_parser("local-test",
                       help="Run VFS CI mkosi build & tests locally")
    p.add_argument("-k", "--kernel-src", required=True,
                   help="Kernel source directory")
    p.add_argument("-d", "--directory", default="/tmp",
                   help="Base directory for cloned repos "
                        "(mkosi-kernel, fstests, etc.; default: /tmp)")
    p.add_argument("--distro", default="fedora",
                   help="Distribution (default: fedora)")
    p.add_argument("--suite",
                   choices=["selftests", "xfstests", "ovl-fstests"],
                   help="Test suite to run (default: all)")

    return parser.parse_args()


COMMANDS = {
    "sync": cmd_sync,
    "bridge": cmd_bridge,

    "delete": cmd_delete,
    "cancel": cmd_cancel,
    "reset": cmd_reset,
    "status": cmd_status,
    "ci-results": cmd_ci_results,
    "local-test": cmd_local_test,
}


def main():
    C.init()
    args = parse_args()

    if args.command in GH_COMMANDS:
        check_gh()

    COMMANDS[args.command](args)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\nInterrupted")
        sys.exit(130)
